<% layout("/layouts/boilerplate") -%>

<div class="row mt-3">
    <h1 class="col-6 offset-3">Login</h1>
    <div class="col-6 offset-3">
      <form action="/login" method="post">
        <div class="mb-3">
            <label for="username" class="form-label" novalidate class="needs-validation">Username</label>
            <input 
            name="username"
            id="username"
            placeholder="enter username"
            type="text"
            class="form-control"
            required
            />
        </div>
           <div class="mb-3">
            <label for="password" class="form-label" novalidate class="needs-validation">Password</label>
            <input 
            name="password"
            id="password"
            placeholder="enter your password"
            type="password"
            class="form-control"
            required
            />
        </div>
        <button type="submit" class="btn btn-dark">Login</button>
      </form>
      </div>
      </div>